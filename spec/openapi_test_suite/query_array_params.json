  {
    "description": "Array query params with typed items are coerced",
    "schema": {
      "openapi": "3.1.0",
      "info": {
        "title": "api",
        "version": "1.0.0"
      },
      "paths": {
        "/": {
          "get": {
            "parameters": [
              {
                "in": "query",
                "required": true,
                "name": "ids",
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "minimum": 1
                  }
                }
              }
            ],
            "responses": {
              "200": {
                "description": "Success",
                "content": {
                  "application/json": {
                    "schema": {}
                  }
                }
              }
            }
          }
        }
      }
    },
    "tests": [
