        "description": "request with integer values is valid",
        "data": {
          "method": "get",
          "path": "/",
          "request": {
            "query": "ids=1&ids=2",
            "headers": {
              "Content-Type": "application/json"
            }
          },
          "response": {
            "status": 200,
